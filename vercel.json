{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':(exclude)data/forensics' && exit 0 || exit 1",
  "rewrites": [
    { "source": "/((?!api/|models/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/surveillance/feed.js": { "maxDuration": 45 },
    "api/forensics/subjects.js": { "includeFiles": "data/forensics/**" },
    "api/forensics/harvard-shadow.js": { "includeFiles": "data/forensics/**" },
    "api/forensics/harvard-subjects.js": { "includeFiles": "data/forensics/**" },
    "api/forensics/subject.js": { "includeFiles": "data/forensics/**" },
    "api/forensics/diagnose.js": { "includeFiles": "data/forensics/**", "maxDuration": 30 }
  }
}
